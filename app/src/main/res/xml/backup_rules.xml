<?xml version="1.0" encoding="utf-8"?>
<!--
    Nirog Bhumi stores health, profile, consultation, payment-adjacent and
    consent data. Backup is disabled in AndroidManifest.xml; this file keeps the
    legacy full-backup surface explicit for older platform tooling.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
