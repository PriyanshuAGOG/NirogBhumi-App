<?xml version="1.0" encoding="utf-8"?>
<!--
    Disable Android 12+ cloud backup and device-to-device transfer for app data.
    Firebase remains the authoritative encrypted backend; local device data may
    contain health records, consent state, reports, expert notes, and cached
    user/session material that should not be copied outside the authenticated
    Firebase account flow.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
