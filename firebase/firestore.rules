rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function role(name) { return signedIn() && (request.auth.token.role == name || ('roles' in request.auth.token && request.auth.token.roles is list && name in request.auth.token.roles)); }
    function admin() { return role('admin') || role('super_admin'); }
    function expert() { return role('expert'); }
    function assigned(uid) { return expert() && exists(/databases/$(database)/documents/expertAssignments/$(request.auth.uid + '_' + uid)); }
    function ownsResource() { return owner(resource.data.userId); }
    function ownsRequest() { return owner(request.resource.data.userId); }
    function preservesUserId() { return request.resource.data.userId == resource.data.userId; }
    function validCreate() { return ownsRequest() && request.resource.data.createdAt == request.time; }

    match /users/{uid} {
      allow create: if owner(uid) && request.resource.data.userId == uid && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow read: if owner(uid) || admin() || assigned(uid);
      allow update: if admin() || (owner(uid) && (!('role' in resource.data) || request.resource.data.role == resource.data.role) && (!('status' in resource.data) || request.resource.data.status == resource.data.status));
      allow delete: if admin();
    }
    match /profiles/{id} {
      allow create: if validCreate();
      allow read: if ownsResource() || admin() || assigned(resource.data.userId);
      allow update: if admin() || (ownsResource() && ownsRequest() && preservesUserId()) || (assigned(resource.data.userId) && preservesUserId());
      allow delete: if ownsResource() || admin();
    }
    match /{collection}/{id} {
      allow create: if collection in ['glucoseReadings','bpReadings','sleepLogs','walkLogs','weightLogs','labReports','dailyCheckins','checklistLogs'] && validCreate();
      allow read, delete: if collection in ['glucoseReadings','bpReadings','sleepLogs','walkLogs','weightLogs','labReports','dailyCheckins','checklistLogs'] && (ownsResource() || admin() || assigned(resource.data.userId));
      allow update: if collection in ['glucoseReadings','bpReadings','sleepLogs','walkLogs','weightLogs','labReports','dailyCheckins','checklistLogs'] && (admin() || (ownsResource() && ownsRequest() && preservesUserId()) || (assigned(resource.data.userId) && preservesUserId()));
    }
    match /consultations/{id} {
      allow create: if validCreate() && request.resource.data.paymentStatus == 'pending' && request.resource.data.status in ['pending', 'payment_pending'];
      allow read: if ownsResource() || admin() || (expert() && resource.data.expertId == request.auth.uid);
      allow update: if admin() || (expert() && resource.data.expertId == request.auth.uid && preservesUserId()) || (ownsResource() && ownsRequest() && preservesUserId() && request.resource.data.paymentStatus == resource.data.paymentStatus && request.resource.data.status == resource.data.status);
    }
    match /{collection}/{id} {
      allow read: if collection in ['dailyActions','weeklyReports','sugarStories','userPrograms','programPlans','expertNotes','notifications','deviceConnections','orders'] && (ownsResource() || admin() || assigned(resource.data.userId));
      allow create: if collection == 'deviceConnections' && ownsRequest();
      allow update: if collection == 'deviceConnections' && ownsResource() && ownsRequest() && preservesUserId();
      allow create: if collection == 'orders' && validCreate() && request.resource.data.paymentStatus == 'pending' && request.resource.data.orderStatus == 'pending';
      // The device itself (local reminder fired, FCM message received) is the
      // one recording that a notification happened, so a self-scoped create
      // is safe - it can only ever write an entry claiming to be its own user.
      allow create: if collection == 'notifications' && validCreate();
    }
    match /contentItems/{id} { allow read: if resource.data.status == 'published' || admin(); allow write: if admin() || role('content_manager'); }
    match /programs/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /consultationSlots/{id} { allow read: if signedIn() && resource.data.active == true; allow write: if admin() || expert(); }
    match /expertAssignments/{id} { allow read: if admin() || (expert() && resource.data.expertId == request.auth.uid); allow write: if admin(); }
    match /{collection}/{id} {
      allow create: if collection in ['dataExportRequests','deletionRequests'] && validCreate();
      allow read: if collection in ['dataExportRequests','deletionRequests'] && (ownsResource() || admin());
      allow update: if admin();
    }
    match /auditLogs/{id} { allow read: if admin(); allow write: if false; }
    match /supportRequests/{id} {
      allow create: if validCreate() && request.resource.data.status == 'open';
      allow read: if ownsResource() || admin();
      allow update: if admin();
    }
    match /{document=**} { allow read, write: if false; }
  }
}
