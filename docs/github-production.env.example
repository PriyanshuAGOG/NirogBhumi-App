# GitHub "production" environment checklist
#
# This is a reference list, not a file GitHub reads. Add each value as a
# secret on the repository's "production" environment
# (Settings > Environments > production > Environment secrets).
# Never commit real values.

## Firebase project bootstrap
# Firebase CLI token from `firebase login:ci`, used only to run
# .github/workflows/setup-firebase-project.yml (register the Android app,
# export google-services.json, optionally deploy firebase.json auth config).
FIREBASE_TOKEN=

# Base64 of the real app/google-services.json for project nirog-bhumi-app,
# app ID 1:126409331898:android:b4e478566dcbeeb7009e83. Produced by:
#   npx -y firebase-tools@latest apps:sdkconfig ANDROID \
#     1:126409331898:android:b4e478566dcbeeb7009e83 --project nirog-bhumi-app \
#     | base64 -w 0
# Consumed by .github/workflows/build-firebase-debug-apk.yml (debug) and
# .github/workflows/release-android.yml (signed release bundle).
GOOGLE_SERVICES_JSON_BASE64=

## Firebase deploy (rules/indexes/storage/functions)
# Service-account JSON (base64 or raw) with Firebase Admin access, used by
# .github/workflows/deploy-firebase.yml via google-github-actions/auth.
FIREBASE_SERVICE_ACCOUNT_JSON=

## Signed Play release (release-android.yml, upload-google-play.yml)
ANDROID_KEYSTORE_BASE64=
ANDROID_STORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Play Console service-account JSON for automated AAB uploads.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
